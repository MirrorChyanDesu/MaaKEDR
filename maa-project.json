    "resources": [
        {
            "enabled": true,
            "label": "Base",
            "path": "resource/base",
            "slug": "base"
        },
        {
            "enabled": true,
            "label": "Bilibili",
            "path": "resource/bilibili",
            "slug": "bilibili"
        },
        {
            "enabled": true,
            "label": "TapTap",
            "path": "resource/taptap",
            "slug": "taptap"
        }
    ],
    "runtime": {
        "mfa": {
            "channel": "v2.12.2-beta.3",
            "enabled": true
        },
        "mxu": {
            "channel": "latest",
            "enabled": true
        }
