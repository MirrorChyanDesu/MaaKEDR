{
    "addons": {
        "autoFormat": {
            "enabled": true
        },
        "community": {
            "enabled": true
        },
        "dependabot": {
            "enabled": true
        },
        "devTools": {
            "enabled": true
        },
        "gitCliff": {
            "enabled": true
        },
        "github": {
            "enabled": true
        },
        "optimizeImages": {
            "enabled": true
        },
        "schemaSync": {
            "enabled": true
        }
    },
    "controller": {
        "kinds": [
            "Adb"
        ]
    },
    "features": {
        "ci": {
            "enabled": true
        },
        "quality": {
            "enabled": true
        },
        "release": {
            "enabled": true
        },
