{
    "devDependencies": {
        "@nekosu/maa-tools": "1.0.24",
        "@nekosu/prettier-plugin-maafw-sort": "1.0.5",
        "@vue/runtime-core": "^3.5.39",
        "@vuepress/bundler-vite": "2.0.0-rc.30",
        "ajv": "8.20.0",
        "ajv-formats": "3.0.1",
        "gray-matter": "^4.0.3",
        "http-server": "^14.1.1",
        "jsonc-parser": "3.3.1",
        "katex": "0.16.38",
        "prettier": "3.8.4",
        "prettier-plugin-multiline-arrays": "4.1.9",
        "pyright": "^1.1.400",
        "sass": "^1.101.0",
        "sass-embedded": "^1.100.0",
        "typescript": "^5.9.3",
        "vue": "^3.5.40",
        "vuepress": "2.0.0-rc.30",
        "vuepress-theme-plume": "1.0.0-rc.204"
    },
    "engines": {
        "node": ">=24"
    },
    "license": "AGPL-3.0-or-later",
    "name": "maakedr",
    "packageManager": "pnpm@11.5.1",
    "private": true,
    "scripts": {
        "check": "pnpm format:check && pnpm check:schema && pnpm check:maa && pnpm lint",
        "check:ci": "pnpm format:check && pnpm lint",
        "check:maa": "pnpm exec maa-tools check",
        "check:py": "uv run ruff check . && uv run pyright",
        "check:schema": "node tools/validate-schema.mjs",
        "docs:build": "vuepress build docs --clean-cache --clean-temp && node tools/fix-docs-urls.mjs",
        "docs:dev": "vuepress dev docs --clean-cache --clean-temp",
        "docs:preview": "http-server docs/.vuepress/dist",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "node tools/check-project.mjs",
        "optimize:images": "node tools/optimize-images.mjs",
        "release:dry-run": "node tools/build-release.mjs --dry-run",
        "sync:runtime": "node tools/sync-runtime.mjs",
        "sync:schema": "node tools/sync-schema.mjs",
        "vp-update": "pnpm dlx vp-update"
    },
    "type": "module",
    "version": "0.1.0"
}
