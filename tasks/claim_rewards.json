{
    "task": [
        {
            "name": "领取奖励",
            "entry": "ClaimRewards",
            "default_check": true,
            "group": ["Daily"],
            "description": "一键领取各类奖励。包含每日/每周/军旅成就奖励、战令通行证奖励、邮箱奖励、资源派遣奖励。支持各奖励类型独立开关",
            "option": [
                "claim_dispatch",
                "claim_daily_rewards",
                "claim_battle_pass",
                "claim_mailbox"
            ]
        }
    ],
    "option": {
        "claim_dispatch": {
            "type": "switch",
            "label": "派遣任务领取",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "option": [
                        "dispatch_redeploy"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "DispatchClaim.Start": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "dispatch_redeploy": {
            "type": "switch",
            "label": "再次派遣",
            "description": "领取奖励后选择再次派遣，否则直接关闭",
            "default_case": "No",
            "cases": [
                {
                    "name": "No",
                    "pipeline_override": {
                        "DispatchClaim.ClaimButton": {
                            "next": [
                                "Common.CheckItemObtained",
                                "DispatchClaim.RedeployConfirm",
                                "DispatchClaim.Exit"
                            ]
                        },
                        "DispatchClaim.RedeployConfirm": {
                            "recognition": "DirectHit",
                            "action": {
                                "type": "DoNothing"
                            },
                            "next": [
                                "DispatchClaim.Exit"
                            ]
                        }
                    }
                },
                {
                    "name": "Yes"
                }
            ]
        },
        "claim_daily_rewards": {
            "type": "switch",
            "label": "每日/每周/军旅成就奖励",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes"
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "ClaimRewards.Start": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "claim_battle_pass": {
            "type": "switch",
            "label": "战令通行证奖励",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes"
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "BattlePass.Start": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "claim_mailbox": {
            "type": "switch",
            "label": "邮箱奖励",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes"
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "Mailbox.Start": {
                            "enabled": false
                        }
                    }
                }
            ]
        }
    }
}
