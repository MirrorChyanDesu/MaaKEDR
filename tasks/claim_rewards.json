{
    "task": [
        {
            "name": "领取奖励",
            "entry": "ClaimRewards.Start",
            "option": [
                "claim_daily_rewards",
                "claim_battle_pass",
                "claim_mailbox"
            ]
        }
    ],
    "option": {
        "claim_daily_rewards": {
            "type": "switch",
            "label": "每日/每周/军旅成就奖励",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes"
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "ClaimRewards.Start": {
                            "recognition": "DirectHit",
                            "action": {"type": "DoNothing"},
                            "next": ["BattlePass.Start"],
                            "on_error": ["BattlePass.Start"]
                        }
                    }
                }
            ]
        },
        "claim_battle_pass": {
            "type": "switch",
            "label": "战令通行证奖励",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes"
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "BattlePass.Start": {
                            "recognition": "DirectHit",
                            "action": {"type": "DoNothing"},
                            "next": ["Mailbox.Start"],
                            "on_error": ["Mailbox.Start"]
                        }
                    }
                }
            ]
        },
        "claim_mailbox": {
            "type": "switch",
            "label": "邮箱奖励",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes"
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "Mailbox.Start": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "claim_dispatch": {
            "type": "switch",
            "label": "派遣任务领取",
            "default_case": "No",
            "cases": [
                {
                    "name": "No"
                },
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "Mailbox.BackButton": {
                            "next": [
                                "DispatchClaim.Start"
                            ]
                        }
                    }
                }
            ]
        }
    }
}
