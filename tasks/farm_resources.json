{
    "task": [
        {
            "name": "资源刷取",
            "entry": "FarmResources.CheckHomePage",
            "default_check": true,
            "group": ["Daily"],
            "description": "自动刷取资源关卡。支持资源收集(特别军费行动/作战体能训练/兵种能力评级/载具对抗演练)和技能演练(基础技能/专业技能)。支持普通次数模式与清空体力模式",
            "option": [
                "farm_category",
                "farm_battle_mode"
            ]
        }
    ],
    "option": {
        "farm_battle_mode": {
            "type": "switch",
            "label": "清空体力",
            "default_case": "No",
            "cases": [
                {
                    "name": "No"
                },
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "FarmResources.QuickBattle": {
                            "next": [
                                "FarmResources.SetBattleCountMax"
                            ]
                        },
                        "FarmResources.CheckStamina": {
                            "next": [
                                "FarmResources.ReduceCount"
                            ]
                        },
                        "FarmResources.BattleStage": {
                            "next": [
                                "[JumpBack]FarmResources.ClickVictory",
                                "[JumpBack]FarmResources.ClickItemDialog",
                                "FarmResources.ResetCountTarget"
                            ]
                        },
                        "FarmResources.ExitStage": {
                            "next": [
                                "FarmResources.BattleStage"
                            ]
                        },
                        "FarmResources.ExitStageConfirm": {
                            "next": [
                                "FarmResources.BattleStage"
                            ]
                        }
                    }
                }
            ]
        },
        "farm_battle_count": {
            "type": "select",
            "label": "战斗次数",
            "default_case": "1次",
            "cases": [
                {
                    "name": "1次",
                    "label": "1次",
                    "pipeline_override": {
                        "FarmResources.SetBattleCount": {
                            "custom_action_param": "{\"target_count\": 1, \"count_roi\": [903, 441, 27, 43], \"plus_button\": [1086, 470], \"minus_button\": [739, 470], \"max_template\": \"farm_resources/max_count.png\"}"
