    "agent": [
        {
            "child_exec": "python",
            "child_args": ["-u", "./agent/bootstrap.py"],
            "identifier": "maakedr_agent"
        }
    ],
    "import": [
        "./tasks/startup.json",
        "./tasks/claim_rewards.json",
        "./tasks/farm_resources.json"
    ]
