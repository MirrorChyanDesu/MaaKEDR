{
    "interface_version": 2,
    "name": "maakedr",
    "label": "MaaKEDR",
    "version": "v0.1.0",
    "icon": "logo.ico",
    "contact": "QQ群: 1051890489",
    "license": "LICENSE",
    "welcome": "./resource/base/WELCOME.md",
    "description": "MaaKEDR MaaFW project",
    "controller": [
        {
            "name": "Android",
            "label": "Android / Emulator",
            "type": "Adb",
            "display_short_side": 720
        }
    ],
    "resource": [
        {
            "name": "base",
            "label": "官服",
            "path": [
                "./resource/base"
            ]
        },
        {
            "name": "bilibili",
            "label": "B 服",
            "path": [
                "./resource/base",
                "./resource/bilibili"
            ]
        },
        {
            "name": "taptap",
            "label": "TapTap 服",
            "path": [
                "./resource/base",
                "./resource/taptap"
            ]
        }
    ],
    "agent": [
        {
            "child_exec": "uv",
            "child_args": [
                "run",
                "python",
                "-u",
                "./agent/bootstrap.py"
            ],
            "identifier": "maakedr_agent"
        }
    ],
    "import": [
        "./tasks/startup.json",
        "./tasks/claim_rewards.json",
        "./tasks/farm_resources.json"
    ]
}
