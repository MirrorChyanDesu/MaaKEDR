{
    "interface_version": 2,
    "name": "maakedr",
    "label": "MaaKEDR",
    "version": "v0.1.0",
    "icon": "logo.ico",
    "description": "MaaKEDR MaaFW project",
    "controller": [
        {
            "name": "Android",
            "label": "Android / Emulator",
